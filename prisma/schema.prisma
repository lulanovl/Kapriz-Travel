generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SENIOR_MANAGER
  MANAGER
  FINANCE
}

enum ApplicationStatus {
  NEW
  CONTACT
  PROPOSAL
  DEPOSIT
  IN_BUS
  NO_SHOW
  ON_TOUR
  FEEDBACK
  ARCHIVE
}

enum GuidePaymentStatus {
  PENDING      // not marked by guide yet
  PAID         // tourist paid balance to guide
  TRANSFERRED  // tourist paid to manager/company
  NO_SHOW      // tourist didn't show up (marked by guide)
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum Currency {
  KGS
  USD
  EUR
}

enum DepartureStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum ScheduleType {
  WEEKLY
  DATE_RANGE
}

// ─── 1. Users (CRM staff) ───────────────────────────────────────────────────
model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  password       String
  role           Role     @default(MANAGER)
  telegramChatId String?
  createdAt      DateTime @default(now())

  applications Application[]
  reminders    Reminder[]

  @@map("users")
}

// ─── 2. Clients (tourists) ──────────────────────────────────────────────────
model Client {
  id        String   @id @default(cuid())
  name      String
  whatsapp  String   @unique
  country   String?
  city      String?
  tag       String?
  source    String?
  notes     String?
  noShow    Boolean  @default(false)
  createdAt DateTime @default(now())

  applications Application[]
  reviews      Review[]

  @@map("clients")
}

// ─── 3. Tours ───────────────────────────────────────────────────────────────
model Tour {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  description    String?  @db.Text
  itinerary      Json?
  included       Json?
  notIncluded    Json?
  basePrice      Int
  minGroupSize   Int      @default(1)
  maxGroupSize   Int      @default(20)
  duration       Int?
  tourType       String?
  isActive       Boolean  @default(true)
  images         Json?
  mapEmbed       String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  schedules    TourSchedule[]
  departures   Departure[]
  applications Application[]

  @@map("tours")
}

// ─── 4. Tour Schedules (recurring rules configured by managers) ─────────────
// Используются как шаблон для создания выездов. Менеджер подтверждает каждый выезд вручную.
model TourSchedule {
  id         String       @id @default(cuid())
  tourId     String
  type       ScheduleType
  // WEEKLY: дни недели [0=Вс, 1=Пн, 2=Вт, 3=Ср, 4=Чт, 5=Пт, 6=Сб]
  daysOfWeek Int[]
  // DATE_RANGE: диапазон дат (напр. праздничные выезды)
  rangeStart DateTime?
  rangeEnd   DateTime?
  note       String?      // напр. "Праздничные выезды 1-10 мая"
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())

  tour Tour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_schedules")
}

// ─── 5. Departures (конкретная дата выезда, подтверждённая менеджером) ──────
model Departure {
  id            String          @id @default(cuid())
  tourId        String
  departureDate DateTime
  status        DepartureStatus @default(OPEN)
  note          String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tour          Tour           @relation(fields: [tourId], references: [id], onDelete: Cascade)
  applications  Application[]
  groups        Group[]
  reviews       Review[]
  extraExpenses ExtraExpense[]

  @@map("departures")
}

// ─── 6. Groups (автобус/группа внутри выезда, создаётся менеджером) ─────────
model Group {
  id          String   @id @default(cuid())
  departureId String
  name        String   // "Автобус 1", "Группа А"
  guideId     String?
  driverId    String?
  maxSeats    Int      @default(15)
  notes       String?
  createdAt   DateTime @default(now())

  departure    Departure     @relation(fields: [departureId], references: [id], onDelete: Cascade)
  guide        Staff?        @relation("GroupGuide", fields: [guideId], references: [id])
  driver       Staff?        @relation("GroupDriver", fields: [driverId], references: [id])
  applications Application[]
  expenses     Expense[]
  guideTokens  GuideToken[]

  @@map("groups")
}

// ─── 7. Applications ────────────────────────────────────────────────────────
model Application {
  id          String            @id @default(cuid())
  clientId    String
  tourId      String
  departureId String?           // выезд (выбирается туристом на сайте)
  groupId     String?           // автобус (назначается менеджером после набора)
  persons     Int               @default(1)
  comment     String?           @db.Text
  status      ApplicationStatus @default(NEW)
  managerId   String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  isWaitlist  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client     Client      @relation(fields: [clientId], references: [id])
  tour       Tour        @relation(fields: [tourId], references: [id])
  departure  Departure?  @relation(fields: [departureId], references: [id])
  group      Group?      @relation(fields: [groupId], references: [id])
  manager    User?       @relation(fields: [managerId], references: [id])
  booking    Booking?
  reminders  Reminder[]
  companions Companion[]

  @@map("applications")
}

// ─── 7b. Companions (попутчики в заявке) ────────────────────────────────────
model Companion {
  id            String   @id @default(cuid())
  applicationId String
  name          String
  whatsapp      String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("companions")
}

// ─── 8. Bookings ────────────────────────────────────────────────────────────
model Booking {
  id                String        @id @default(cuid())
  applicationId     String        @unique
  basePrice         Int
  finalPrice        Int
  priceChangeReason String?
  currency          Currency      @default(KGS)
  depositPaid       Int           @default(0)
  depositDate       DateTime?
  paymentStatus     PaymentStatus @default(PENDING)
  noShow             Boolean            @default(false)
  guidePaymentStatus GuidePaymentStatus @default(PENDING)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  application  Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  priceHistory PriceHistory[]

  @@map("bookings")
}

// ─── 9. Price History ───────────────────────────────────────────────────────
model PriceHistory {
  id        String   @id @default(cuid())
  bookingId String
  changedBy String
  oldPrice  Int
  newPrice  Int
  reason    String?
  changedAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("price_history")
}

// ─── 10. Expenses (расходы на уровне группы/автобуса) ───────────────────────
model Expense {
  id        String   @id @default(cuid())
  groupId   String
  category  String   // free-form: "Питание", "Бензин", "Ночлег", etc.
  amount    Int
  currency  Currency        @default(KGS)
  note      String?
  createdAt DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ─── 11. Staff (guides & drivers) ───────────────────────────────────────────
model Staff {
  id             String @id @default(cuid())
  name           String
  role           String
  phone          String?
  telegramChatId String?

  guideGroups  Group[] @relation("GroupGuide")
  driverGroups Group[] @relation("GroupDriver")

  @@map("staff")
}

// ─── 12. Reminders ──────────────────────────────────────────────────────────
model Reminder {
  id            String   @id @default(cuid())
  applicationId String
  userId        String
  dueAt         DateTime
  note          String?
  isDone        Boolean  @default(false)
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@map("reminders")
}

// ─── 13. Reviews ────────────────────────────────────────────────────────────
model Review {
  id          String   @id @default(cuid())
  clientId    String
  departureId String
  rating      Int
  text        String?  @db.Text
  isPublished Boolean  @default(false)
  token       String   @unique @default(cuid())
  createdAt   DateTime @default(now())

  client    Client    @relation(fields: [clientId], references: [id])
  departure Departure @relation(fields: [departureId], references: [id])

  @@map("reviews")
}

// ─── 14. Extra Expenses (marketing/targeting costs per departure) ───────────
// Финансист вводит расходы на рекламу/таргет, привязанные к конкретному выезду.
// Вычитаются из чистой прибыли тура при расчёте зарплаты менеджеров.
model ExtraExpense {
  id          String   @id @default(cuid())
  departureId String
  amount      Int
  currency    Currency @default(KGS)
  description String   @default("")
  createdAt   DateTime @default(now())

  departure Departure @relation(fields: [departureId], references: [id], onDelete: Cascade)

  @@map("extra_expenses")
}

// ─── 15. Guide Tokens (токен для страницы гида, на уровне группы) ───────────
model GuideToken {
  id        String   @id @default(cuid())
  groupId   String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("guide_tokens")
}
